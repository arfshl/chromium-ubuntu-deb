author: Andres Salomon <dilinger@debian.org>

Work around a missing string_hash(), not present in trixie's gn version.


ERROR at //build/rust/gni_impl/rust_target.gni:51:17: Unknown function.
    _dir_hash = string_hash(get_label_info(":${_target_name}", "dir"))
                ^----------

--- a/build/rust/gni_impl/rust_target.gni
+++ b/build/rust/gni_impl/rust_target.gni
@@ -48,7 +48,8 @@ template("rust_target") {
   if (defined(invoker.crate_name)) {
     _crate_name = invoker.crate_name
   } else {
-    _dir_hash = string_hash(get_label_info(":${_target_name}", "dir"))
+    lbl = get_label_info(":${_target_name}", "dir")
+    _dir_hash = string_join("", exec_script("//stringhash.py", [ lbl ], "list lines"))
     _crate_name = "${_target_name}_${_dir_hash}"
   }
   _generate_crate_root =
