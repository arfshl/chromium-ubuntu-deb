The bindgen build rules need to know the location of the rustfmt binary and
the libclang shared library.

--- a/build/rust/rust_bindgen_generator.gni
+++ b/build/rust/rust_bindgen_generator.gni
@@ -36,6 +36,10 @@ if (!use_chromium_rust_toolchain &&
   _libclang_path += "/lib"
 }
 
+# Debian overrides to the above
+_rustfmt_path  = "/usr/bin/rustfmt"
+_libclang_path = clang_base_path + "/lib"
+
 # Template to build Rust/C bindings with bindgen.
 #
 # If you're developing first-party code then consider using `rust_bindgen`
